{
  "name": "image-resize-compress",
  "version": "2.1.1",
  "description": "Image resizer, compressor, and converter built with modern TypeScript support",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "eslint ./src/* ./tests ./vitest.config.ts",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}'",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "image",
    "resize",
    "compress",
    "reduce",
    "png",
    "jpeg",
    "webp",
    "react",
    "typescript"
  ],
  "author": "Alef Duarte",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alefduarte/image-resize-compress.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.1",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.16.0",
    "generate-changelog": "^1.8.0",
    "globals": "^15.12.0",
    "playwright": "^1.61.1",
    "prettier": "3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
