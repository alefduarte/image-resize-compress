{
  "name": "image-resize-compress",
  "version": "2.1.1",
  "description": "Resize, compress, and convert images in the browser from a File, Blob, or URL - ~3 kB, zero runtime dependencies, TypeScript-first",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint ./src/* ./tests ./vitest.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "demo": "pnpm dlx serve demo",
    "size": "size-limit",
    "publint": "publint --pack npm",
    "attw": "attw --pack",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "image",
    "resize",
    "compress",
    "reduce",
    "png",
    "jpeg",
    "webp",
    "react",
    "typescript"
  ],
  "author": "Alef Duarte",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alefduarte/image-resize-compress.git"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.1",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "playwright": "^1.61.1",
    "prettier": "3.9.6",
    "publint": "^0.3.21",
    "semantic-release": "^25.0.8",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "2.8 kB"
    },
    {
      "path": "dist/index.global.js",
      "limit": "3.1 kB"
    }
  ]
}
